{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "create_checkpoint",
  "description": "Input for the MCP create_checkpoint tool. Use after a Phase, or after a long stretch of work.",
  "type": "object",
  "properties": {
    "project_id": { "type": "string" },
    "agent_name": { "type": "string" },
    "current_focus_node_id": { "type": "string" },
    "completed": { "type": "array", "items": { "type": "string" } },
    "in_progress": { "type": "array", "items": { "type": "string" } },
    "next": { "type": "array", "items": { "type": "string" } },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "related_node_ids": { "type": "array", "items": { "type": "string" } },
    "summary": { "type": "string" }
  },
  "required": ["project_id"],
  "additionalProperties": true
}
