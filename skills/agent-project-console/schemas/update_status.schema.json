{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "update_status",
  "description": "Input for the MCP update_status tool.\n- status='done' requires evidence_summary.\n- status='blocked' requires blocker_reason and next_action.\n- Rolling back from done requires rollback_reason.",
  "type": "object",
  "properties": {
    "node_id": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["planned", "ready", "in_progress", "blocked", "review", "done", "skipped", "cancelled"]
    },
    "progress": { "type": "number", "minimum": 0, "maximum": 100 },
    "evidence_summary": { "type": "string" },
    "blocker_reason": { "type": "string" },
    "impact": { "type": "string" },
    "next_action": { "type": "string" },
    "needs_human": { "type": "boolean" },
    "rollback_reason": { "type": "string" },
    "override_reason": { "type": "string" },
    "reason": { "type": "string" }
  },
  "required": ["node_id", "status"],
  "additionalProperties": true,
  "allOf": [
    {
      "if": { "properties": { "status": { "const": "done" } } },
      "then": { "required": ["evidence_summary"] }
    },
    {
      "if": { "properties": { "status": { "const": "blocked" } } },
      "then": { "required": ["blocker_reason", "next_action"] }
    }
  ]
}
